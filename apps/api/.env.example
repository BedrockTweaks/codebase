# Required environment variables
NODE_PORT=8000
PRODUCTION=false

# Absolute path to storage directory containing pack files
# Example: /opt/bedrock_tweaks/files_dev
STORAGE_URL=/path/to/storage

# Comma-separated list of pack authors for manifest generation
# Example: "Author1, Author2, Author3"
METADATA_AUTHORS=BedrockTweaks

# Optional cache directory for assembled packs
# If omitted, the API uses the OS temp directory
# Example: /var/cache/bedrock-tweaks/assembly
# CACHE_DIR=/var/cache/bedrock-tweaks/assembly

# Optional max assembly cache size in bytes (LRU eviction)
# If omitted, defaults to 4294967296 (4 GB)
# Example: 8589934592 (8 GB)
# CACHE_MAX_BYTES=4294967296

# Optional directory for generated download zips
# If omitted, the API uses the OS temp directory
# Example: /var/cache/bedrock-tweaks/downloads
# DOWNLOADS_DIR=/var/cache/bedrock-tweaks/downloads

# Optional max downloads directory size in bytes (LRU eviction)
# If omitted, defaults to 4294967296 (4 GB)
# Example: 8589934592 (8 GB)
# DOWNLOADS_MAX_BYTES=4294967296
